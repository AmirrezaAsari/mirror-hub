# Application
NODE_ENV=development
PORT=3000
APP_PORT=3002

# PostgreSQL
POSTGRES_USER=mirror
POSTGRES_PASSWORD=mirror_secret
POSTGRES_DB=mirror_hub
POSTGRES_PORT=5432

# Prisma
DATABASE_URL=postgresql://mirror:mirror_secret@localhost:5432/mirror_hub?schema=public

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3001

# Frontend
FRONTEND_PORT=3001
